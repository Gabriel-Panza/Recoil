func _ready() -> void:
	_load_language()
	TranslationServer.set_locale(current_language)

func set_language(language: String) -> void:
	var safe_language = _sanitize_language(language)
	if safe_language == current_language:
		return
	current_language = safe_language
	TranslationServer.set_locale(current_language)
	_save_language()
	language_changed.emit(current_language)

func toggle_language() -> void:
	set_language(LANG_PT_BR if current_language == LANG_EN else LANG_EN)

func get_language() -> String:
	return current_language

func t(key: String, params: Array = []) -> String:
	var text = _get_translation_text(key)
	if params.is_empty():
		return text
	return text % params

func has_key(key: String) -> bool:
	return TEXT.get(current_language, {}).has(key) or TEXT[LANG_EN].has(key)

func defeated_sins(amount: int) -> String:
	var safe_amount = clampi(amount, 0, 7)
	if safe_amount == 1:
		return t("sins.one")
	return t("sins.many", [safe_amount])

func arm_name(arm_id: String, fallback: String = "") -> String:
	return _text_or_fallback("arm.%s.name" % arm_id, fallback if fallback != "" else arm_id)

func arm_description(arm_id: String, fallback: String = "") -> String:
	return _text_or_fallback("arm.%s.description" % arm_id, fallback)

func arm_option_name(arm_id: String, fallback: String = "") -> String:
	return _text_or_fallback("arm.%s.option_name" % arm_id, fallback if fallback != "" else arm_id)

func arm_summary(arm_id: String, fallback: String = "") -> String:
	return _text_or_fallback("arm.%s.summary" % arm_id, fallback)

func arm_details(arm_id: String, fallback: String = "") -> String:
	return _text_or_fallback("arm.%s.details" % arm_id, fallback)

func option_text(option_id: String, fallback: String = "") -> String:
	return _text_or_fallback("option.%s.text" % option_id, fallback if fallback != "" else option_id)

func option_name(option_id: String, fallback: String = "") -> String:
	var name_key = "option.%s.name" % option_id
	if has_key(name_key):
		return t(name_key)
	return option_text(option_id, fallback)

func option_description(option_id: String, fallback: String = "") -> String:
	return _text_or_fallback("option.%s.description" % option_id, fallback)

func mutation_name(arm_id: String, tier: int, fallback: String = "") -> String:
	return _text_or_fallback("mutation.%s.%d.name" % [arm_id, tier], fallback)

func mutation_description(arm_id: String, tier: int, fallback: String = "") -> String:
	return _text_or_fallback("mutation.%s.%d.description" % [arm_id, tier], fallback)

func _get_translation_text(key: String) -> String:
	var language_table: Dictionary = TEXT.get(current_language, {})
	if language_table.has(key):
		return str(language_table[key])
	return str(TEXT[LANG_EN].get(key, key))

func _text_or_fallback(key: String, fallback: String) -> String:
	if has_key(key):
		return t(key)
	return fallback

func _sanitize_language(language: String) -> String:
	return LANG_PT_BR if language == LANG_PT_BR else LANG_EN

func _load_language() -> void:
	var config = ConfigFile.new()
	if config.load(SETTINGS_PATH) == OK:
		current_language = _sanitize_language(str(config.get_value(SETTINGS_SECTION, SETTINGS_LANGUAGE_KEY, LANG_EN)))
	else:
		current_language = LANG_EN

func _save_language() -> void:
	var config = ConfigFile.new()
	config.load(SETTINGS_PATH)
	config.set_value(SETTINGS_SECTION, SETTINGS_LANGUAGE_KEY, current_language)
	var save_error = config.save(SETTINGS_PATH)
	if save_error != OK:
		push_error("Failed to persist language at %s: %s" % [ProjectSettings.globalize_path(SETTINGS_PATH), error_string(save_error)])
	elif OS.has_feature("web") and not OS.is_userfs_persistent():
		push_warning("Language was saved for this session, but the browser reports that user:// is not persistent.")
